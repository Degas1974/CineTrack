{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Swagger": {
    "Enabled": false
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Security": {
    "ApiKey": "__CONFIGURE_API_KEY__"
  },
  "ConnectionStrings": {
    "DefaultConnection": "__CONFIGURE_DEFAULT_CONNECTION__"
  },
  "Scraping": {
    "SceneSource": {
      "Categories": [
        "tv",
        "films/bluray",
        "tv/miniseries"
      ],
      "MaxPagesPerCategory": 3,
      "MaxPostsPerPage": 20,
      "StorePostUrlOnly": true
    }
  },
  "ImdbDatasets": {
    "Directory": "__CONFIGURE_IMDB_DATASET_DIRECTORY__",
    "FallbackWebEnabled": false
  },
  "RottenTomatoes": {
    "Provider": "Disabled"
  },
  "Translation": {
    "Provider": "LibreTranslate",
    "BaseUrl": "http://localhost:5000/",
    "SourceLanguage": "en",
    "TargetLanguage": "pt",
    "ApiKey": ""
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5050"
      }
    }
  }
}
